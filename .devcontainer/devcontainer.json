{
  "name": "arissa",
  "image": "mcr.microsoft.com/devcontainers/go:1-trixie",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "runArgs": ["--platform=linux/amd64"],
  "postCreateCommand": "go mod download",
  "customizations": {
